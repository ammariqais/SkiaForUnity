  m_Name: 
  m_EditorClassIdentifier: SkiaSharp.Unity::SkiaSharp.Unity.HB.HB_TEXTBlock
  Text: "\u062A\u064E\u062A\u064E\u062D\u064E\u062F\u064E\u0651\u062B \u0627\u064E\u0644\u0652\u0623\u064E\u0628\u0652\u064A\u064E\u0627\u062A
    \u0639\u064E\u0646\u0652 \u0644\u064E\u062D\u0652\u0638\u064E\u0629 \u0648\u064E\u062F\u064E\u0627\u0639
    \u064A\u064E\u0633\u0652\u062A\u064E\u063A\u0652\u0631\u0650\u0628 \u0641\u0650\u064A\u0647\u064E\u0627
    \u0627\u064E\u0644\u0634\u064E\u0651\u0627\u0639\u0650\u0631 \u0623\u064E\u0646\u0652
    \u0644\u064E\u0627 \u064A\u064E\u0628\u0652\u0643\u0650\u064A \u0645\u0650\u0646\u0652
    \u0623\u064E\u0644\u064E\u0645 \u0627\u064E\u0644\u0652\u0641\u0650\u0631\u064E\u0627\u0642\u060C
    \u0648\u064E\u064A\u064E\u0635\u0650\u0641 \u062D\u064E\u0627\u0644\u064E\u0629
    \u0627\u064E\u0644\u0652\u0645\u064F\u0648\u062F\u0650\u0639\u0650\u064A\u0646\u064E
    \u0648\u064E\u0628\u064E\u0639\u0652\u0636\u0647\u0645\u0652 \u064A\u064E\u062A\u064E\u0643\u064E\u0644\u064E\u0651\u0645
    \u0641\u0650\u064A \u062D\u0650\u064A\u0646 \u064A\u064E\u0643\u0652\u062A\u064E\u0641\u0650\u064A
    \u0627\u064E\u0644\u0652\u0645\u064F\u062D\u0650\u0628\u064F\u0651\u0648\u0646\u064E
    \u0628\u0650\u0627\u0644\u0635\u064E\u0651\u0645\u0652\u062A\u0650\u060C \u0644\u0650\u0623\u064E\u0646\u064E\u0651
    \u062D\u064E\u0627\u0644\u0647\u0645\u0652 \u062A\u064E\u0638\u0652\u0647\u064E\u0631
    \u0639\u0650\u0634\u0652\u0642\u0647\u0645\u0652 \u0623\u064E\u0643\u0652\u062B\u064E\u0631
    \u0645\u0650\u0645\u064E\u0651\u0627 \u064A\u064E\u0633\u0652\u062A\u064E\u0637\u0650\u064A\u0639\u064F\u0648\u0646\u064E
    \u0627\u064E\u0644\u062A\u064E\u0651\u0639\u0652\u0628\u0650\u064A\u0631 \u0639\u064E\u0646\u0652\u0647\u064F
    \u0628\u0650\u0627\u0644\u0652\u0643\u064E\u0644\u064E\u0627\u0645\u0650. \u0648\u064E\u064A\u064F\u0642\u064E\u0633\u0650\u0651\u0645
    \u0641\u0650\u064A \u0622\u062E\u064E\u0631 \u0627\u064E\u0644\u0652\u0623\u064E\u0628\u0652\u064A\u064E\u0627\u062A
    \u0639\u064E\u0644\u064E\u0649 \u0623\u064E\u0646\u064E\u0651 \u062A\u064E\u0648\u064E\u0642\u064F\u0651\u0641
    \u062F\u064E\u0645\u0652\u0639\u0647 \u0644\u064E\u0627 \u064A\u064E\u0639\u0652\u0646\u0650\u064A
    \u0646\u0650\u0647\u064E\u0627\u064A\u064E\u0629 \u062D\u064E\u064A\u0651\u0647."
